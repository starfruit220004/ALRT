# Environment Variables Template
# Copy this to .env, .env.local, or .env.production and fill in the values

# Backend API URL - Change this when you deploy
VITE_API_URL=http://localhost:5000

# WebSocket/Socket.io Server URL - Usually same as API_URL
VITE_SOCKET_URL=http://localhost:5000

# Environment type (development, production, staging)
VITE_ENV=development

# EXAMPLES FOR DIFFERENT HOSTING:
# ────────────────────────────────────────────
# For Local Development:
#   VITE_API_URL=http://localhost:5000
#   VITE_SOCKET_URL=http://localhost:5000
#
# For Heroku Backend:
#   VITE_API_URL=https://your-app-name.herokuapp.com
#   VITE_SOCKET_URL=https://your-app-name.herokuapp.com
#
# For Railway Backend:
#   VITE_API_URL=https://your-app-name.up.railway.app
#   VITE_SOCKET_URL=https://your-app-name.up.railway.app
#
# For Render Backend:
#   VITE_API_URL=https://your-app-name.onrender.com
#   VITE_SOCKET_URL=https://your-app-name.onrender.com
#
# For AWS/Custom Server:
#   VITE_API_URL=https://api.yourdomain.com
#   VITE_SOCKET_URL=https://api.yourdomain.com
