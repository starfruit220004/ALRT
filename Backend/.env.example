# Backend Environment Variables Template
# Copy this to .env and fill in your actual values

# ════════════════════════════════════════════
# DATABASE CONFIGURATION
# ════════════════════════════════════════════
DATABASE_URL="postgresql://username:password@localhost:5432/database_name"
# Examples:
#   Local: DATABASE_URL="postgresql://postgres:password@localhost:5432/alrt_db"
#   Railway: DATABASE_URL="postgresql://user:pass@host:port/dbname"
#   Heroku: DATABASE_URL="postgres://..."

# ════════════════════════════════════════════
# SERVER CONFIGURATION
# ════════════════════════════════════════════
PORT=5000
NODE_ENV=development
# NODE_ENV options: development, production, staging

# ════════════════════════════════════════════
# JWT & AUTHENTICATION
# ════════════════════════════════════════════
JWT_SECRET=your-super-secret-jwt-key-change-in-production
# IMPORTANT: Change this in production to a strong random string

# ════════════════════════════════════════════
# FRONTEND URLS (for CORS)
# ════════════════════════════════════════════
FRONTEND_URL=http://localhost:5173
# Examples for production:
#   Vercel: FRONTEND_URL=https://your-app-name.vercel.app
#   Netlify: FRONTEND_URL=https://your-app-name.netlify.app
#   Custom Domain: FRONTEND_URL=https://yourdomain.com

# ════════════════════════════════════════════
# EMAIL CONFIGURATION
# ════════════════════════════════════════════
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-specific-password
# Note: Use App-Specific Password for Gmail (not your regular password)

# ════════════════════════════════════════════
# MQTT CONFIGURATION
# ════════════════════════════════════════════
MQTT_BROKER=mqtt://broker.hivemq.com:1883
# Other MQTT brokers:
#   HiveMQ: mqtt://broker.hivemq.com:1883
#   Mosquitto: mqtt://broker.mosquitto.org:1883
#   Local: mqtt://localhost:1883

# ════════════════════════════════════════════
# SECURITY
# ════════════════════════════════════════════
ADMIN_SECRET=change-this-secret-in-production
