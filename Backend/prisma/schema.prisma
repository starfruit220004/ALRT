generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Alert {
  id         Int       @id @default(autoincrement())
  message    String?
  sensorData Json?     @map("sensor_data") @db.Json
  createdAt  DateTime? @default(now()) @map("created_at") @db.Timestamp(6)

  @@map("alerts")
}

model CMS {
  id        Int      @id @default(autoincrement())
  section   String   @db.VarChar(50)
  key       String   @db.VarChar(100)
  value     String
  updatedAt DateTime @updatedAt @map("updatedat") @db.Timestamptz(6)

  @@unique([section, key])
  @@map("cms")
}

model DoorLog {
  id        Int       @id @default(autoincrement())
  status    String?   @db.VarChar(10)
  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  userId    Int?      @map("user_id")
  user      User?     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("door_logs")
}

model Settings {
  id            Int      @id @default(autoincrement())
  alarmEnabled  Boolean? @default(false) @map("alarm_enabled")
  smsEnabled    Boolean? @default(true) @map("sms_enabled")
  userId        Int?     @unique @map("user_id")
  scheduleStart String?  @default("08:00") @map("schedule_start") @db.VarChar(5)
  scheduleEnd   String?  @default("17:00") @map("schedule_end") @db.VarChar(5)
  user          User?    @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("settings")
}

model SmsLog {
  id        Int       @id @default(autoincrement())
  status    String    @db.VarChar(50)
  userId    Int?      @map("user_id")
  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  user      User?     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("sms_logs")
}

model User {
  id            Int       @id @default(autoincrement())
  name          String?
  email         String?   @unique
  password      String?
  role          String?   @default("user") @db.VarChar(20)
  resetToken    String?   @map("reset_token")
  avatar        String?
  mqttTopic     String?   @map("mqtt_topic") @db.VarChar(255)
  phone         String?   @db.VarChar(15)
  username      String?   @db.VarChar(50)
  firstName     String?   @map("first_name") @db.VarChar(100)
  lastName      String?   @map("last_name") @db.VarChar(100)
  middleName    String?   @map("middle_name") @db.VarChar(100)
  address       String?
  isActive      Boolean   @default(true) @map("is_active")
  deactivatedAt DateTime? @map("deactivated_at") @db.Timestamptz(6)
  isVerified    Boolean   @default(false) @map("is_verified")
  verifyToken   String?   @map("verify_token")
  doorLogs      DoorLog[]
  settings      Settings?
  smsLogs       SmsLog[]

  @@map("users")
}
